# Postgres secrets
# admin (superuser) — только для бэкапов и pgvector extension
POSTGRES_DB=saiga
POSTGRES_USER=saiga_admin
POSTGRES_PASSWORD=generate_via_openssl_rand_base64_32

# migrator — owner БД, DDL права. Используется ТОЛЬКО Alembic-ом
# в entrypoint.sh web-контейнера (через MIGRATION_DATABASE_URL).
SAIGA_MIGRATOR_PASSWORD=generate_via_openssl_rand_base64_32

# app — runtime web/bot, только DML (SELECT/INSERT/UPDATE/DELETE).
# Не может CREATE/ALTER/DROP — защита от exfilration через runtime-секрет.
SAIGA_APP_PASSWORD=generate_via_openssl_rand_base64_32
