# Bearer-токен для /embed и /embed/batch. Сгенерировать:
#   openssl rand -hex 32
EMBEDDING_API_KEY=

# Опционально: переопределить модель. По умолчанию intfloat/multilingual-e5-large
# (1024 dim). Если меняешь — синхронизируй EMBEDDING_DIM в коде клиента и
# vector(N) в Alembic миграции (на ходу не сменить — нужен новый индекс).
# EMBEDDING_MODEL=intfloat/multilingual-e5-large
