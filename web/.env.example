# Saiga Web App secrets
# Сгенерировать: openssl rand -hex 32
SECRET_KEY=generate_random_64char_hex_for_flask_sessions

# PostgreSQL — пароль saiga_app см. postgres/.env (SAIGA_APP_PASSWORD)
DATABASE_URL=postgresql://saiga_app:PASSWORD@saiga-postgres:5432/saiga

# Telegram (web использует токен только для проверки подписи логина из бота)
TELEGRAM_BOT_TOKEN=your_bot_token_from_BotFather
TELEGRAM_BOT_USERNAME=saiga_ai_bot

# Sentry (optional)
SENTRY_DSN=
SENTRY_ENV=production

# SMTP для email-верификации.
# Production: Resend с verified custom domain — см. https://resend.com/docs/send-with-smtp
#   SMTP_USER=resend (всегда литерально "resend"), SMTP_PASSWORD=<API key из resend.com/api-keys>
#   SMTP_FROM=noreply@<твой verified domain>
# Альтернативы: smtp.yandex.ru / smtp.gmail.com / smtp.mail.ru — но deliverability на
# другие провайдеры (mail.ru/gmail) хуже без custom domain DKIM.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USER=resend
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# Embedding service (saiga-embedding на homeserver).
# URL — внутрь docker-сети (saiga-internal). Снаружи не торчит.
EMBEDDING_API_URL=http://saiga-embedding:8000
# Тот же что в embedding/.env. Сгенерировать: openssl rand -hex 32
EMBEDDING_API_KEY=
