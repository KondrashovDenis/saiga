# Saiga Web App secrets
# Сгенерировать: openssl rand -hex 32
SECRET_KEY=generate_random_64char_hex_for_flask_sessions

# PostgreSQL — пароль saiga_app см. postgres/.env (SAIGA_APP_PASSWORD)
DATABASE_URL=postgresql://saiga_app:PASSWORD@saiga-postgres:5432/saiga

# Telegram (web использует токен только для проверки подписи логина из бота)
TELEGRAM_BOT_TOKEN=your_bot_token_from_BotFather
TELEGRAM_BOT_USERNAME=saiga_ai_bot

# Sentry (optional)
SENTRY_DSN=
SENTRY_ENV=production

# SMTP для email-верификации (Yandex / Gmail / любой). Если пусто — register
# создаёт юзеров без отправки письма (юзер не сможет войти, пока email_verified=true
# не будет проставлен вручную или не настроится SMTP).
#
# Yandex: app password создаётся в https://id.yandex.ru/security → "Пароли приложений"
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USER=denciaopin@yandex.ru
SMTP_PASSWORD=
SMTP_FROM=denciaopin@yandex.ru
