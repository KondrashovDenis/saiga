# Caddyfile для vaibkod.ru
#
# Что делает:
#   vaibkod.ru, www.vaibkod.ru → static landing из /srv/landing
#   saiga.vaibkod.ru           → saiga-web-app:5000 (Flask, без auth — внутри web свой login)
#   llm.vaibkod.ru             → saiga-llm:5000 с проверкой Authorization: Bearer
#
# TLS — автоматический LetsEncrypt. Email берётся из глобального блока.
# Сертификаты и stat в volume caddy-data (сохраняются между перезапусками).

{
    email {$LE_EMAIL}
    # Минимальные тайм-ауты для idle (Caddy default ок), большие — на route
}

# ──────────────── LANDING ────────────────
vaibkod.ru, www.vaibkod.ru {
    encode gzip zstd
    root * /srv/landing
    file_server
    log {
        output stdout
        format console
    }
}

# ──────────────── WEB-APP ────────────────
saiga.vaibkod.ru {
    encode gzip zstd
    reverse_proxy saiga-web-app:5000 {
        # Flask/Werkzeug — небольшие таймауты
        transport http {
            read_timeout 60s
            write_timeout 60s
        }
    }
}

# ──────────────── LLM API (с Bearer-auth) ────────────────
llm.vaibkod.ru {
    encode gzip zstd

    # Проверка Bearer-токена. Если не совпадает — 401.
    @authorized header Authorization "Bearer {$LLM_API_KEY}"

    handle @authorized {
        # Длинные таймауты — генерация может идти 30+ сек
        reverse_proxy saiga-llm:5000 {
            transport http {
                read_timeout 600s
                write_timeout 600s
            }
            flush_interval -1  # стримим SSE без буферизации
        }
    }

    handle {
        respond "Unauthorized" 401 {
            close
        }
    }
}
