# Caddyfile для vaibkod.ru
#
# Что делает:
#   vaibkod.ru, www.vaibkod.ru → reverse_proxy vaibkod-cms:8000 (Wagtail CMS, gunicorn)
#   saiga.vaibkod.ru           → saiga-web-app:5000 (Flask, без auth — внутри web свой login)
#   llm.vaibkod.ru             → saiga-llm:5000 (OpenAI API) с проверкой Authorization: Bearer
#   saigaui.vaibkod.ru         → saiga-llm:7860 (Gradio UI, text-generation-webui) с HTTP Basic Auth
#   metrics.vaibkod.ru         → grafana:3000 с HTTP Basic Auth (observability dashboards)
#
# TLS — автоматический LetsEncrypt. Email берётся из глобального блока.

{
    email {$LE_EMAIL}
}

# ──────────────── Reusable security-headers snippet ────────────────
# Подключение в site-блоке: `import security_headers`.
# CSP подбирается отдельно для каждого сайта (разные inline-скрипты).
(security_base) {
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        -Server
    }
}

# ──────────────── LANDING (Wagtail CMS) ────────────────
vaibkod.ru, www.vaibkod.ru {
    encode gzip zstd
    import security_base
    reverse_proxy vaibkod-cms:8000 {
        transport http {
            read_timeout 60s
            write_timeout 60s
        }
    }
    log {
        output stdout
        format console
    }
}

# ──────────────── WEB-APP ────────────────
saiga.vaibkod.ru {
    encode gzip zstd
    import security_base
    header {
        # Inline <script> блоки в layout.html / login.html / settings.html
        # требуют 'unsafe-inline'. Когда вынесем во внешний .js — удалить.
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
    }
    reverse_proxy saiga-web-app:5000 {
        transport http {
            read_timeout 60s
            write_timeout 60s
        }
    }
}

# ──────────────── LLM API (Bearer-auth) ────────────────
llm.vaibkod.ru {
    encode gzip zstd
    import security_base

    @authorized header Authorization "Bearer {$LLM_API_KEY}"

    handle @authorized {
        reverse_proxy saiga-llm:5000 {
            transport http {
                read_timeout 600s
                write_timeout 600s
            }
            flush_interval -1  # стримим SSE без буферизации
        }
    }

    handle {
        respond "Unauthorized" 401 {
            close
        }
    }
}

# ──────────────── LLM Web UI (HTTP Basic Auth) ────────────────
saigaui.vaibkod.ru {
    encode gzip zstd
    import security_base

    basic_auth {
        denciao $2a$14$rdiH8msX3HizdEeaIT6/Lux38mc0dAB2tDmM5xQIngE2EaSXbNsEm
    }

    reverse_proxy saiga-llm:7860 {
        transport http {
            read_timeout 600s
            write_timeout 600s
        }
    }
}

# ──────────────── Metrics dashboards (HTTP Basic Auth) ────────────────
# Grafana у нас в private docker network. Caddy достаёт её из общей сети
# nginx-proxy (Grafana подключена и туда). Basic_auth — первый слой защиты;
# второй слой — собственный Grafana login (см. monitoring/.env).
metrics.vaibkod.ru {
    encode gzip zstd
    import security_base

    basic_auth {
        denciao $2a$14$OxmZ1HLJFcA7NFZrItGO0.X33nUEUNM/T0xRwDpDl3/uozf0e82AG
    }

    reverse_proxy grafana:3000 {
        transport http {
            read_timeout 60s
            write_timeout 60s
        }
    }
}

# ──────────────── ARTK (MVP транспортной компании) ────────────────
artk.retreathub.ru {
    encode gzip zstd

    # REC-1: security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "same-origin"
        # Минимальный CSP — Next.js нуждается в inline-скриптах
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'"
        # Скрываем мета-инфо
        -Server
        -X-Powered-By
    }

    # Django: API, админка, статика (whitenoise), медиа
    @backend path /api/* /admin/* /static/* /media/* /healthz
    handle @backend {
        reverse_proxy artk_backend:8000 {
            transport http {
                read_timeout 60s
                write_timeout 60s
            }
        }
    }

    # Next.js: всё остальное (фронт + его _next/* ассеты)
    handle {
        reverse_proxy artk_frontend:3000 {
            transport http {
                read_timeout 60s
                write_timeout 60s
            }
        }
    }
}
