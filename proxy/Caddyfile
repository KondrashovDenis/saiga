# Caddyfile для vaibkod.ru
#
# Что делает:
#   vaibkod.ru, www.vaibkod.ru → reverse_proxy vaibkod-cms:8000 (Wagtail CMS, gunicorn)
#   saiga.vaibkod.ru           → saiga-web-app:5000 (Flask, без auth — внутри web свой login)
#   llm.vaibkod.ru             → saiga-llm:5000 (OpenAI API) с проверкой Authorization: Bearer
#   saigaui.vaibkod.ru         → saiga-llm:7860 (Gradio UI, text-generation-webui) с HTTP Basic Auth
#   metrics.vaibkod.ru         → grafana:3000 с HTTP Basic Auth (observability dashboards)
#
# TLS — автоматический LetsEncrypt. Email берётся из глобального блока.

{
    email {$LE_EMAIL}
}

# ──────────────── Reusable security-headers snippet ────────────────
# Подключение в site-блоке: `import security_headers`.
# CSP подбирается отдельно для каждого сайта (разные inline-скрипты).
(security_base) {
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        -Server
    }
}

# ──────────────── LANDING (Wagtail CMS) ────────────────
# /admin/* и /django-admin/* за basic_auth (второй слой поверх Wagtail login).
# Пароль для basic_auth: ~/projects/vaibkod-landing/cms/docker/supss/admin-basic-auth.txt
vaibkod.ru, www.vaibkod.ru {
    encode gzip zstd
    import security_base
    header {
        # Wagtail admin требует unsafe-inline для inline JS/CSS из кода.
        # Внешний сайт тоже имеет inline стили (inline style="..." в шаблонах).
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' fonts.googleapis.com; font-src 'self' fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
    }
    request_body {
        max_size 5MB
    }

    @admin path /admin* /django-admin*
    handle @admin {
        basic_auth {
            denciao $2a$14$geOtkdVDz2yaznvlcWUwBObNZugi9.EltRS.vXbbu6HSx6iPMLc0O
        }
        reverse_proxy vaibkod-cms:8000 {
            transport http {
                read_timeout 60s
                write_timeout 60s
            }
        }
    }

    handle {
        reverse_proxy vaibkod-cms:8000 {
            transport http {
                read_timeout 60s
                write_timeout 60s
            }
        }
    }

    log {
        output stdout
        format console
    }
}

# ──────────────── WEB-APP ────────────────
saiga.vaibkod.ru {
    encode gzip zstd
    import security_base
    header {
        # Inline <script> вынесены во внешние .js (см. static/js/),
        # 'unsafe-inline' для script-src снят. style-src оставлен с
        # 'unsafe-inline' — много inline style="..." в шаблонах, отдельная задача.
        Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
    }
    reverse_proxy saiga-web-app:5000 {
        transport http {
            read_timeout 60s
            write_timeout 60s
        }
    }
}

# ──────────────── LLM API (Bearer-auth) ────────────────
llm.vaibkod.ru {
    encode gzip zstd
    import security_base

    @authorized header Authorization "Bearer {$LLM_API_KEY}"

    handle @authorized {
        reverse_proxy saiga-llm:5000 {
            transport http {
                read_timeout 600s
                write_timeout 600s
            }
            flush_interval -1  # стримим SSE без буферизации
        }
    }

    handle {
        respond "Unauthorized" 401 {
            close
        }
    }
}

# ──────────────── LLM Web UI (HTTP Basic Auth) ────────────────
saigaui.vaibkod.ru {
    encode gzip zstd
    import security_base

    basic_auth {
        denciao $2a$14$rdiH8msX3HizdEeaIT6/Lux38mc0dAB2tDmM5xQIngE2EaSXbNsEm
    }

    reverse_proxy saiga-llm:7860 {
        transport http {
            read_timeout 600s
            write_timeout 600s
        }
    }
}

# ──────────────── Metrics dashboards (HTTP Basic Auth) ────────────────
# Grafana у нас в private docker network. Caddy достаёт её из общей сети
# nginx-proxy (Grafana подключена и туда). Basic_auth — первый слой защиты;
# второй слой — собственный Grafana login (см. monitoring/.env).
metrics.vaibkod.ru {
    encode gzip zstd
    import security_base

    basic_auth {
        denciao $2a$14$OxmZ1HLJFcA7NFZrItGO0.X33nUEUNM/T0xRwDpDl3/uozf0e82AG
    }

    reverse_proxy grafana:3000 {
        transport http {
            read_timeout 60s
            write_timeout 60s
        }
    }
}

# ──────────────── ARTK (MVP транспортной компании) ────────────────
artk.retreathub.ru {
    encode gzip zstd

    # REC-1: security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "same-origin"
        # Минимальный CSP — Next.js нуждается в inline-скриптах
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'"
        # Скрываем мета-инфо
        -Server
        -X-Powered-By
    }

    # Django: API, админка, статика (whitenoise), медиа
    @backend path_regexp ^/(api|admin|static|media|healthz)
    handle @backend {
        reverse_proxy artk_backend:8000 {
            transport http {
                read_timeout 60s
                write_timeout 60s
            }
        }
    }

    # Next.js: всё остальное (фронт + его _next/* ассеты)
    handle {
        reverse_proxy artk_frontend:3000 {
            transport http {
                read_timeout 60s
                write_timeout 60s
            }
        }
    }
}

# ──────────────── Embedding API (Bearer-auth) ────────────────
# saiga-embedding (multilingual-e5-large) для внешних клиентов: Glow на debianOCR,
# будущие проекты. Bearer = EMBEDDING_API_KEY (см. embedding/.env, sync с клиентом).
# Внутри docker-сети homeserver web/bot ходят напрямую через saiga-internal,
# не через этот блок.
embedding.vaibkod.ru {
    encode gzip zstd
    import security_base

    @authorized header Authorization "Bearer {$EMBEDDING_API_KEY}"

    handle @authorized {
        reverse_proxy saiga-embedding:8000 {
            transport http {
                read_timeout 60s
                write_timeout 60s
            }
        }
    }

    handle {
        respond "Unauthorized" 401 {
            close
        }
    }
}

imagegen.vaibkod.ru {
    encode gzip zstd
    import security_base

    @authorized header Authorization "Bearer {$IMAGEGEN_API_KEY}"

    handle @authorized {
        reverse_proxy saiga-imagegen:8000 {
            transport http {
                # ControlNet генерация может занять до 60 сек
                read_timeout 180s
                write_timeout 180s
            }
        }
    }

    handle {
        respond "Unauthorized" 401 {
            close
        }
    }
}
